{%- if include_linear_mcp -%}
{
  "_comment": "Run /mcp in Claude Code to authenticate with Linear.",
  "mcpServers": {
    "linear": {
      "type": "http",
      "url": "https://mcp.linear.app/mcp"
    }{% if include_playwright %},
    "playwright": {
      "type": "stdio",
      "command": "npx",
      "args": ["@playwright/mcp"]
    }{% endif %}
  }
}
{%- else -%}
{
  "mcpServers": {}
}
{%- endif %}
